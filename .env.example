# =============================================
# IMPACT TRACKER — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values
# =============================================

# --- GitHub App ---
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=         # Base64-encoded .pem file content
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Database ---
DATABASE_URL=postgresql://impact:impact_pass@localhost:5432/impact_tracker

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- AI Classification ---
# Primary: Google Gemini (free tier — 1,500 req/day)
GEMINI_API_KEY=

# Fallback: OpenRouter (free tier — Llama 3.1 8B)
OPENROUTER_API_KEY=

# --- Admin ---
ADMIN_API_KEY=              # Protects /api/admin/* endpoints

# --- App URLs ---
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# --- Environment ---
NODE_ENV=development
