{
  "name": "impact-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "Open Source Impact Tracker — Measure the real-world social impact of GitHub repositories",
  "author": "Impact Tracker Team",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "pnpm db:generate && turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "db:generate": "pnpm --filter @impact/database db:generate",
    "db:push": "pnpm --filter @impact/database db:push",
    "db:migrate": "pnpm --filter @impact/database db:migrate",
    "db:studio": "pnpm --filter @impact/database db:studio",
    "heroku-postbuild": "pnpm db:generate && pnpm build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3"
  }
}
